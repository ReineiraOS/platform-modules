{
  "name": "@reineira-os/modules-app",
  "version": "0.1.0",
  "private": true,
  "description": "Platform app starter for ReineiraOS ventures — React 19, ZeroDev, passkey auth",
  "type": "module",
  "scripts": {
    "dev": "vite --port 4831",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "generate:types": "openapi-typescript ../backend/openapi.json -o src/generated/api-types.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-slot": "^1",
    "@tanstack/react-query": "^5",
    "@tanstack/react-router": "^1",
    "@zerodev/ecdsa-validator": "^5.4.9",
    "@zerodev/passkey-validator": "^5.6.0",
    "@zerodev/permissions": "^5.6.3",
    "@zerodev/sdk": "^5.5.7",
    "@zerodev/webauthn-key": "^5.5.0",
    "@cofhe/sdk": "^0.4.0",
    "tfhe": "0.11.1",
    "axios": "^1",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3",
    "viem": "^2",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^26",
    "openapi-typescript": "^7",
    "tailwindcss": "^4",
    "typescript": "^5.7",
    "vite": "^6",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^3"
  },
  "license": "MIT"
}
